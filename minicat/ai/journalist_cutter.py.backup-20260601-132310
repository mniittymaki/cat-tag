  "selected_segments": [
    {{
      "source_in": 12.45,               // float seconds from original transcript (source time)
      "source_out": 28.9,
      "text": "Exact text from the transcript",
      "reason": "Brief editorial justification (max 18 words)"
    }}
  ]

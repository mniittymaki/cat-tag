def _batch_delete_selected(state: AppState) -> None:
    """Delete all currently multi-selected items from the DB (with confirmation)."""
    selected = state.get_selected_videos()
    if not selected:
        return

    count = len(selected)

    with ui.dialog() as dialog, ui.card().classes("w-96"):

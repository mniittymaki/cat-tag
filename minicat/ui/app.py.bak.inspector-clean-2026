def _open_sharing_connect_dialog(service: str, service_name: str) -> None:
    """Open a connection dialog for a specific sharing service."""
    with ui.dialog() as dlg, ui.card().classes("w-[480px]"):
        ui.label(f"Connect to {service_name}").classes("text-h6 mb-3")

        if service in ("gdrive", "dropbox"):
            ui.label(
                "OAuth connection is planned. For now you can paste a placeholder token or connection ID. "
                "Real OAuth flow (with proper token storage) will be added in a future update."
            ).classes("text-sm text-grey-6 mb-3")

            token_input = ui.input(
                "Access Token / Connection ID (placeholder)",
                placeholder="Paste token here...",
            ).props("dense").classes("w-full mb-2")

            def save_placeholder():
                token = token_input.value.strip()
                if not token:
                    ui.notify("Please enter a token", color="warning")
                    return
                data = {
                    "connected": True,
                    "type": "oauth_placeholder",
                    "token": token,
                    "connected_at": __import__("datetime").datetime.now().isoformat(),
                }
                set_sharing_connection(service, data)
                ui.notify(f"{service_name} connected (placeholder)", color="positive")
                dlg.close()

            ui.button("Save Connection", on_click=save_placeholder, color="primary").props("size=sm")

        elif service == "nextcloud":
            ui.label("Enter your Nextcloud server details (use an App Password, not your main password).").classes("text-sm mb-3")

            server = ui.input("Server URL", placeholder="https://cloud.example.com").props("dense").classes("w-full mb-1")
            username = ui.input("Username", placeholder="yourname").props("dense").classes("w-full mb-1")
            password = ui.input("App Password", password=True).props("dense").classes("w-full mb-1")

            def save_nextcloud():
                srv = server.value.strip()
                user = username.value.strip()
                pw = password.value.strip()
                if not (srv and user and pw):
                    ui.notify("Please fill in server, username and app password", color="warning")
                    return

                data = {
                    "connected": True,
                    "type": "nextcloud",
                    "server": srv.rstrip("/"),
                    "username": user,
                    "password": pw,  # Note: stored in plaintext like Gemini key for now
                    "connected_at": __import__("datetime").datetime.now().isoformat(),
                }
                set_sharing_connection(service, data)
                ui.notify("Nextcloud connected", color="positive")
                dlg.close()

            ui.button("Connect", on_click=save_nextcloud, color="primary").props("size=sm")

        else:
            ui.label("Unknown service").classes("text-negative")

        with ui.row().classes("justify-end w-full mt-4"):
            ui.button("Cancel", on_click=dlg.close).props("flat")

    dlg.open()



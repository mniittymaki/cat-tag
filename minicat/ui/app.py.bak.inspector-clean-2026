                            with ui.column().classes("max-h-[180px] overflow-auto border border-zinc-700 rounded p-2 text-xs mt-1"):
                                for seg in segments_to_show or []:
                                    start = seg.get("start", "")
                                    text = seg.get("text", "")
                                    ui.markdown(f"**[{start}]** {text}").classes("mb-1")

                            # Translate controls
                            with ui.row().classes("gap-2 mt-2 items-center"):
                                common_langs = [
                                    ("fi", "Finnish 🇫🇮"),
                                    ("sv", "Swedish 🇸🇪"),
                                    ("es", "Spanish 🇪🇸"),
                                    ("de", "German 🇩🇪"),
                                    ("fr", "French 🇫🇷"),
                                    ("ru", "Russian 🇷🇺"),
                                ]
                                trans_select = ui.select(
                                    options={code: label for code, label in common_langs},
                                    value=get_preference("ai.default_translation_lang", "fi"),
                                    label="Translate to",
                                ).props("dense size=sm").classes("w-48")

                                async def do_translate():
                                    await translate_current_transcription(trans_select.value)

                                ui.button("Translate", icon="translate", on_click=do_translate).props("size=sm outline")

            # (Old generic proxy EXPORT button removed during cleanup - replaced by per-section Export as New Clip + Export File)

            def export_srt():
                if not state.selected:
                    return

                v = state.selected
                current_lang = getattr(v, "_current_transcription_lang", "original")

                if current_lang == "original":
                    segments = getattr(v, "transcription_segments", None)
                else:
                    segments = v.translated_transcriptions.get(current_lang) if hasattr(v, "translated_transcriptions") else None

                if not segments:
                    # Fallback to original
                    segments = getattr(v, "transcription_segments", None)

                if not segments:
                    # Last fallback: parse from notes
                    notes = v.notes or ""
                    if "--- AI TRANSCRIPTION JSON ---" not in notes:
                        ui.notify("No transcription available for this clip", color="warning")
                        return
                    try:
                        import json
                        json_part = notes.split("--- AI TRANSCRIPTION JSON ---")[1].split("--- AI Transcription (readable) ---")[0].strip()
                        segments = json.loads(json_part)
                    except Exception:
                        ui.notify("Could not parse transcription", color="warning")
                        return

                # Generate proper .srt
                try:
                    from minicat.ai.transcriber import segments_to_srt
                    srt_content = segments_to_srt(segments)
                    lang_suffix = f"_{current_lang}" if current_lang != "original" else ""
                    out_path = Path.home() / "Downloads" / f"{v.filename.rsplit('.', 1)[0]}{lang_suffix}.srt"
                    out_path.write_text(srt_content, encoding="utf-8")
                    ui.notify(f"Exported .srt to {out_path}", color="positive")
                except Exception as e:
                    ui.notify(f"Failed to export .srt: {e}", color="negative")

            # (Transcription options consolidated inside TRANSCRIBE tab)

            async def translate_current_transcription(target_lang: str):
                if not state.selected or not target_lang:
                    return

                v = state.selected
                source_segments = getattr(v, "transcription_segments", None)
                if not source_segments:
                    ui.notify("No original transcription to translate", color="warning")
                    return

                api_key = get_gemini_api_key()
                if not api_key:
                    ui.notify("Gemini API key required", color="warning")
                    return

                loading = ui.dialog()
                with loading, ui.card().classes("w-[320px]"):
                    ui.label(f"Translating to {target_lang}...").classes("text-center")
                    ui.spinner(size="lg").classes("mx-auto mt-3")
                loading.open()

                try:
                    translated = await asyncio.to_thread(
                        translate_transcription_segments,
                        source_segments,
                        target_lang,
                        api_key,
                        model_name=get_gemini_model(),
                    )

                    if not v.translated_transcriptions:
                        v.translated_transcriptions = {}

                    v.translated_transcriptions[target_lang.lower()] = translated
                    v._current_transcription_lang = target_lang.lower()

                    # Persist structured data to dedicated column
                    import json
                    trans_data = {
                        "original": getattr(v, "transcription_segments", []),
                        "translations": v.translated_transcriptions
                    }
                    db.update_video_fields(
                        state.catalog_root,
                        v.id,
                        transcription=json.dumps(trans_data, ensure_ascii=False),
                    )

                    ui.notify(f"Translated to {target_lang}", color="positive")
                    inspector_content.refresh()

                except Exception as e:
                    ui.notify(f"Translation failed: {e}", color="negative")
                    print(f"[Translation] Error: {e}")
                finally:
                    loading.close()

        else:
            _render_multi_selection_panel(state)

    elif state.selected_project:
        _render_project_inspector(state, state.selected_project)

    else:
        with ui.column().classes("items-center justify-center h-full text-center"):
            ui.label("No clip selected").classes("text-h6 text-grey-6")
            ui.label("Click cards to select clips. Click a project in the left panel for project details.").classes("text-sm text-grey-7 mt-2")



def _render_project_inspector(state: AppState, name: str) -> None:

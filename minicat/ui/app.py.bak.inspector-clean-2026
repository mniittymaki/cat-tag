# ---------------------------------------------------------------------------
# Global-ish state for the current session (single catalog per app instance)
# ---------------------------------------------------------------------------

class AppState:
    def __init__(self, catalog_root: Path):
        self.catalog_root = catalog_root
        self.videos: list[Video] = []
        self.selected: Video | None = None       # Focused clip (shown in inspector)
        self.selected_ids: set[int] = set()      # Multi-selection for batch ops / export
        self.selected_project: str | None = None # Focused project (shown in inspector)
        self.view_mode: str = "grid"             # "grid" or "list"
        self.media_filter: str = "all"           # "all" | "video" | "audio"  (top bar view toggle)

        # List view column customization (user can reorder + hide columns by dragging in settings)
        self.list_column_order: list[str] = []
        self.hidden_list_columns: set[str] = set()

        self.filters = SearchFilters()
        self.all_projects: list[str] = []
        self.all_clients: list[str] = []   # New
        self.all_cameras: list[str] = []
        self.all_locations: list[str] = []
        self.all_tags: list[str] = []

        # Sort options for media view (grid + list)
        self.sort_field: str = "shoot_date"   # filename, shoot_date, import_date, duration
        self.sort_desc: bool = True

        # Raw results from DB (before view filters like media type)
        self._raw_videos: list[Video] = []

    def reload(self) -> None:
        """Reload everything from DB (call after mutations)."""
        self.all_projects = db.get_distinct_values(self.catalog_root, "project")
        self.all_clients = [c.name for c in db.get_clients(self.catalog_root)]  # New
        self.all_cameras = db.get_distinct_values(self.catalog_root, "camera")
        self.all_locations = db.get_distinct_values(self.catalog_root, "location")
        self.all_tags = [t.name for t in db.get_all_tags(self.catalog_root)]

        # Apply current filters
        self._raw_videos = db.search_videos(self.catalog_root, self.filters, limit=500)

        # Apply user-selected sort + media view filter
        self.apply_sort()

    def set_filter_text(self, text: str | None) -> None:
        self.filters.text = text or None
        self.reload()

    def toggle_project(self, project: str) -> None:
        current = self.filters.project or []
        if project in current:
            current = [p for p in current if p != project]
        else:
            current = current + [project]
        self.filters.project = current or None
        self.reload()
        refresh_all_ui(self)

    def toggle_client(self, client_name: str) -> None:
        """Toggle filtering by a client (shows all its projects)."""
        current = self.filters.client or []
        if client_name in current:
            current = [c for c in current if c != client_name]
        else:
            current = current + [client_name]
        self.filters.client = current or None
        self.reload()
        refresh_all_ui(self)

    def toggle_camera(self, camera: str) -> None:
        current = self.filters.camera or []
        if camera in current:
            current = [c for c in current if c != camera]
        else:
            current = current + [camera]
        self.filters.camera = current or None
        self.reload()
        refresh_all_ui(self)

    def toggle_location(self, location: str) -> None:
        current = self.filters.location or []
        if location in current:
            current = [loc for loc in current if loc != location]
        else:
            current = current + [location]
        self.filters.location = current or None
        self.reload()
        refresh_all_ui(self)

    def toggle_tag(self, tag: str) -> None:
        current = self.filters.tags or []
        if tag in current:
            current = [t for t in current if t != tag]
        else:
            current = current + [tag]
        self.filters.tags = current or None
        self.reload()
        refresh_all_ui(self)   # ensure toolbar, drawers, everything stays consistent including current sort mode

    def clear_filters(self) -> None:
        self.filters = SearchFilters()
        self.reload()
        refresh_all_ui(self)

    # --- Project inspector selection (similar to clips) ---
    def select_project(self, name: str) -> None:
        self.selected_project = name
        # Clear clip selection when focusing a project
        self.selected_ids.clear()
        self.selected = None
        inspector_content.refresh()
        ui.update()
        self._update_right_drawer()

    def clear_project_selection(self) -> None:
        self.selected_project = None
        inspector_content.refresh()
        ui.update()
        self._update_right_drawer()

    # ------------------------------------------------------------------
    # Multi-selection support (for batch actions + XML export)
    # ------------------------------------------------------------------
    def is_selected(self, video: Video) -> bool:
        return bool(video.id and video.id in self.selected_ids)

    def toggle_select(self, video: Video) -> None:
        """Toggle a clip in the multi-selection set.
        Work is deferred so clicking checkboxes never blocks the UI.
        """
        if not video.id:
            return

        def _do_toggle():
            if video.id in self.selected_ids:
                self.selected_ids.remove(video.id)
                if self.selected and self.selected.id == video.id:
                    self.selected = None
            else:
                self.selected_ids.add(video.id)
                self.selected = video
            try:
                inspector_content.refresh()
                self._update_right_drawer()
            except Exception as ex:
                print(f"[toggle_select] deferred error: {ex}")

        ui.timer(0.02, _do_toggle, once=True)

    def set_single_selection(self, video: Video) -> None:
        """Direct single selection.
        We defer the expensive inspector render by one tick so the click
        feels responsive even on very large 4K files.
        """
        if not video.id:
            return
        self.selected_ids = {video.id}
        self.selected = video

        def _refresh_inspector():
            try:
                inspector_content.refresh()
                self._update_right_drawer()
            except Exception as e:
                print(f"[set_single_selection] error: {e}")

        # Very short defer makes the selection highlight feel instant
        # while the heavy form builds in the background.
        ui.timer(0.01, _refresh_inspector, once=True)

    def clear_selection(self) -> None:
        self.selected_ids.clear()
        self.selected = None
        inspector_content.refresh()
        main_content.refresh()
        ui.update()
        self._update_right_drawer()

    def _update_right_drawer(self):
        """Show or hide the right drawer depending on current selection state."""
        global RIGHT_DRAWER
        if RIGHT_DRAWER is not None:
            has_selection = bool(self.selected_ids or self.selected_project or self.selected)
            RIGHT_DRAWER.set_value(has_selection)
            ui.update(RIGHT_DRAWER)

    def set_view_mode(self, mode: str) -> None:
        if mode in ("grid", "list"):
            self.view_mode = mode
            main_content.refresh()

    def set_media_filter(self, mode: str) -> None:
        """Top bar view filter: restrict visible library to Video / Audio / All."""
        if mode in ("all", "video", "audio"):
            self.media_filter = mode
            self.apply_sort()
            main_content.refresh()

    def set_sort(self, field: str, desc: bool | None = None):
        """Change the sort order for the media grid/list."""
        valid = {"filename", "shoot_date", "import_date", "duration"}
        if field in valid:
            self.sort_field = field
        if desc is not None:
            self.sort_desc = desc

        self.apply_sort()
        refresh_all_ui(self)  # full consistency (toolbar + grid + sidebars) after sort change

    def apply_sort(self):
        """Sort + apply the current top-bar media view filter (Video / Audio / All)."""
        # Always start from the full raw DB result for this view session
        source = getattr(self, "_raw_videos", None)
        if source is None:
            source = self.videos or []

        if not source:
            self.videos = []
            return

        items = list(source)

        def key_func(v: Video):
            if self.sort_field == "filename":
                return (v.filename or "").lower()
            if self.sort_field == "shoot_date":
                return v.shoot_date or date.min
            if self.sort_field == "import_date":
                return getattr(v, "import_date", None) or datetime.min
            if self.sort_field == "duration":
                return v.duration or 0
            return (v.filename or "").lower()

        items.sort(key=key_func, reverse=self.sort_desc)

        # Apply the top-bar "View" media type filter (Video / Audio / All)
        if self.media_filter != "all":
            try:
                from minicat.cli.main import _is_audio_file
                is_audio_fn = _is_audio_file
            except Exception:
                def is_audio_fn(p: Path) -> bool:
                    return p.suffix.lower() in {
                        ".wav", ".wave", ".mp3", ".m4a", ".aac", ".flac", ".ogg", ".oga",
                        ".aiff", ".aif", ".aifc", ".wma", ".opus",
                    }

            if self.media_filter == "audio":
                items = [v for v in items if is_audio_fn(Path(v.path))]
            else:  # "video"
                items = [v for v in items if not is_audio_fn(Path(v.path))]

        self.videos = items

    def get_selected_videos(self) -> list[Video]:
        """Return the currently multi-selected videos.

        Robust version: always returns the full selection even if some clips
        are no longer in the current filtered `self.videos` result (e.g. after
        changing filters or hitting the 500 result limit).
        """
        id_to_video = {v.id: v for v in self.videos if v.id is not None}
        result: list[Video] = []
        missing_ids: list[int] = []

        for vid in self.selected_ids:
            if vid in id_to_video:
                result.append(id_to_video[vid])
            else:
                missing_ids.append(vid)

        if missing_ids:
            # Fetch the rest from DB so batch dialogs always see the true selection count
            fetched = db.get_videos_by_ids(self.catalog_root, missing_ids)
            result.extend(fetched)

        return result

    def select_video(self, video: Video) -> None:
        # Back-compat: treat as single selection (used by some older paths)
        self.set_single_selection(video)

    def save_video_fields(self, **kwargs: Any) -> None:
        if not self.selected or not self.selected.id:
            return
        db.update_video_fields(self.catalog_root, self.selected.id, **kwargs)
        self.selected = db.get_video_by_path(self.catalog_root, self.selected.path)
        self.reload()
        main_content.refresh()
        inspector_content.refresh()


# Global state (set when the app starts)
STATE: AppState | None = None
CONTENT: ui.element | None = None   # Persistent container for all dynamic content
APP_MODE: str = "welcome"           # "welcome" or "app"

# Reference to the right drawer element so we can show/hide it dynamically
RIGHT_DRAWER: Any = None


def get_state() -> AppState | None:
    return STATE


@ui.refreshable
def main_content() -> None:
    """Central content area only.
    IMPORTANT: This must NEVER contain top-level layout elements
    (header, left_drawer, right_drawer, footer). Those must live
    directly under the @ui.page.
    """
    if APP_MODE == "welcome" or STATE is None:
        _render_welcome_screen()
    else:
        # Only the dynamic central area (grid or list + local footer if desired)
        with ui.element("div").classes("w-full q-pa-none"):
            state = get_state()
            try:
                if state and state.view_mode == "list":
                    create_media_list()
                else:
                    create_media_grid()
            except Exception as render_err:
                import traceback
                traceback.print_exc()
                print(f"[Render] Error in central content: {render_err}")
                with ui.column().classes("w-full p-8 text-center"):
                    ui.label("Error rendering media view").classes("text-h6 text-red")
                    ui.label(str(render_err)).classes("text-sm text-grey-6 mt-2")
                    ui.button("Try Grid View", on_click=lambda: (setattr(state, 'view_mode', 'grid'), main_content.refresh())).classes("mt-4")
                    ui.button("Reload Page", on_click=lambda: ui.navigate.reload()).classes("mt-2")


@ui.refreshable
def inspector_content() -> None:
    """Reactive right inspector panel.
    Supports single clip, multi-selection, and project details.
    """
    state = get_state()
    if state is None:
        with ui.column().classes("items-center justify-center h-full text-center"):
            ui.label("No catalog loaded").classes("text-h6 text-grey-6")
        return

    sel_count = len(state.selected_ids)

    if sel_count > 0:
        # CLIPS SELECTED
        if sel_count == 1:
            if not state.selected:
                sel = state.get_selected_videos()
                state.selected = sel[0] if sel else None
            if not state.selected:
                return
            v = state.selected

            # Legacy hydration from notes removed — modern data is populated directly from the
            # `transcription` DB column in _row_to_video and the transcription worker.
            # The old marker parsing on huge notes blobs was a major source of freezes on
            # long transcribed files (re.finditer + json.loads on 100k+ char strings).
            # If you have very old data that only lives in notes, re-transcribe the clip once.

            v = state.selected

            # NOTE: No automatic call to extract_camera_xml_metadata (or ffprobe / exiftool) here.
            # Clicking any clip — no matter how large — must only load the DB record + the
            # small pre-generated storyboard/thumbnail images. All heavy media probing is
            # deferred to explicit buttons ("Re-extract from Sidecar XML", "Rebuild Previews + Metadata").
            # This is the key optimization so the inspector feels instant even on 4K 60 min clips.

            # CLIPNAME
            ui.label(v.filename).classes("text-h6 font-bold mb-2")

            # Storyboard thumbnail — always visible in the inspector sidebar when available.
            # Scaled to fit the narrow right bar. Click to open full size in dialog.
            try:
                has_storyboard = getattr(v, "storyboard_path", None) and Path(v.storyboard_path).exists()
                if has_storyboard:
                    sb_path = Path(v.storyboard_path)
                    img = ui.image(str(sb_path)).classes(
                        "w-full cursor-pointer hover:opacity-90 transition-opacity"
                    ).style(
                        "max-height: 160px; object-fit: contain; "
                        "border: 1px solid #333; border-radius: 4px; background: #111;"
                    )
                    img.on("click", lambda vv=v: _show_storyboard_dialog(vv))
                    ui.label("Storyboard ready").classes("text-xs text-blue-400 mt-1")
                else:
                    ui.label("No storyboard yet").classes("text-xs text-grey-6 italic mb-1")

                    def _generate_storyboard_now():
                        ui.notify("Generating storyboard in background...", color="info", duration=2)

                        def _do_generate():
                            try:
                                from minicat.core import video as video_core
                                thumb, board = video_core.generate_previews(
                                    v.path, state.catalog_root, v.id
                                )
                                db.update_video_fields(
                                    state.catalog_root,
                                    v.id,
                                    thumbnail_path=str(thumb),
                                    storyboard_path=str(board),
                                )
                                refreshed = db.get_video_by_path(state.catalog_root, v.path)
                                if refreshed:
                                    state.selected = refreshed
                                inspector_content.refresh()
                                main_content.refresh()
                                ui.notify("Storyboard ready", color="positive")
                            except Exception as gen_err:
                                print(f"[Inspector] Background storyboard generation failed: {gen_err}")
                                ui.notify("Failed to generate storyboard", color="negative")

                        asyncio.create_task(asyncio.to_thread(_do_generate))

                    ui.button(
                        "Generate (background)",
                        icon="image",
                        on_click=_generate_storyboard_now
                    ).props("size=xs outline dense").classes("w-full")
            except Exception as sb_err:
                print(f"[Inspector] Storyboard section error for {v.filename}: {sb_err}")
                ui.label("Storyboard unavailable").classes("text-xs text-grey-6 italic mb-2")

            # Helper functions for the action buttons (defined early so they can be referenced
            # from their new locations: Rebuild under storyboard, Re-extract inside Technical Info).
            def reextract_xml():
                if not state.selected or not state.selected.id:
                    return
                try:
                    xml_meta = video.extract_camera_xml_metadata(state.selected.path, enrich_with_exiftool=True)
                    if xml_meta:
                        updates: dict[str, Any] = {}
                        for field in ("camera", "lens", "shoot_date", "iso", "f_number",
                                      "shutter_speed", "focal_length", "white_balance", "gamma", "codec",
                                      "color_primaries", "coding_equations"):
                            if xml_meta.get(field):
                                updates[field] = xml_meta[field]
                        if xml_meta.get("source_xml"):
                            updates["camera_xml_path"] = xml_meta["source_xml"]

                        if updates:
                            db.update_video_fields(state.catalog_root, state.selected.id, **updates)
                            state.selected = db.get_video_by_path(state.catalog_root, state.selected.path)
                            refresh_all_ui(state)
                            ui.notify("Re-extracted camera metadata from sidecar", color="positive")
                        else:
                            ui.notify("No additional data found in XML", color="warning")
                    else:
                        ui.notify("No camera metadata sidecar found next to this clip", color="warning")
                except Exception as e:
                    ui.notify(f"XML extraction failed: {e}", color="negative")

            def rebuild_previews():
                if not state.selected or not state.selected.id:
                    return
                if _rebuild_clip_previews_and_metadata(state, state.selected):
                    state.selected = db.get_video_by_path(state.catalog_root, v.path)
                    refresh_all_ui(state)
                    ui.notify("Previews + metadata refreshed", color="positive")
                else:
                    ui.notify("Failed to rebuild", color="negative")

            async def transcribe_and_translate():
                default_lang = get_preference("ai.default_translation_lang", "en")
                if not state.selected:
                    return

                v = state.selected
                # Create loading dialog in this handler context (safe)
                loading = ui.dialog()
                with loading, ui.card().classes("w-[380px]"):
                    ui.label(f"Transcribing + translating to {default_lang}...").classes("text-center")
                    ui.spinner(size="lg").classes("mx-auto mt-3")
                loading.open()

                try:
                    await _transcribe_video(v)  # pure worker, no UI creation inside

                    if getattr(v, "transcription_segments", None) and default_lang and default_lang != "en":
                        raw_translated = await asyncio.to_thread(
                            translate_transcription_segments,
                            v.transcription_segments,
                            default_lang,
                            get_gemini_api_key(),
                            model_name=get_gemini_model(),
                        )
                        from minicat.ai.transcriber import format_for_finnish_broadcast
                        formatted = format_for_finnish_broadcast(raw_translated)

                        if not v.translated_transcriptions:
                            v.translated_transcriptions = {}
                        v.translated_transcriptions[default_lang] = formatted
                        v._current_transcription_lang = default_lang

                        import json
                        trans_data = {
                            "original": v.transcription_segments,
                            "translations": v.translated_transcriptions
                        }
                        db.update_video_fields(
                            state.catalog_root,
                            v.id,
                            transcription=json.dumps(trans_data, ensure_ascii=False),
                        )
                        inspector_content.refresh()
                        ui.notify(f"Also translated to {default_lang}", color="positive")
                except Exception as e:
                    ui.notify(f"Transcription/translation failed: {e}", color="negative")
                    print(f"[Transcribe+Translate] Error: {e}")
                finally:
                    loading.close()



            # Rebuild Previews & Metadata — placed under the storyboard (user request)
            ui.button("Rebuild Previews + Metadata", on_click=rebuild_previews, icon="refresh").props("size=sm outline").classes("w-full mt-1 mb-2")

            # (TRANSCRIBE moved to its correct position after TECHNICAL INFO)

            # AI Tag Suggestions (Gemini) — definition moved early so the button inside CLIP DETAILS can reference it
            async def suggest_ai_tags():
                if not state.selected:
                    return

                has_storyboard = bool(getattr(state.selected, "storyboard_path", None))
                has_transcript = bool(getattr(state.selected, "transcription_segments", None))

                if not has_storyboard and not has_transcript:
                    ui.notify("AI tags require a storyboard (video) or transcription (audio)", color="warning")
                    return

                api_key = get_gemini_api_key()
                if not api_key:
                    ui.notify("Please set your Gemini API key in Settings first", color="warning")
                    return

                # Open one dialog that will show the full flow (loading → results)
                with ui.dialog() as ai_dialog, ui.card().classes("w-[480px]") as card:
                    # Phase 1: Show AI processing state
                    with card:
                        ui.label("Contacting Gemini...").classes("text-h6 text-center mb-2")
                        label_text = "Analyzing storyboard with AI" if has_storyboard else "Analyzing transcript with AI"
                        ui.label(label_text).classes("text-sm text-grey-6 text-center mb-4")
                        ui.spinner(size="xl").classes("mx-auto")

                    async def run_ai_analysis():
                        try:
                            if has_storyboard:
                                suggestions = await asyncio.to_thread(
                                    suggest_tags_from_storyboard,
                                    state.selected.storyboard_path,
                                    api_key,
                                    min_tags=3,
                                    max_tags=8,
                                    model_name=get_gemini_model(),
                                )
                            else:
                                suggestions = await asyncio.to_thread(
                                    suggest_tags_from_transcript,
                                    state.selected.transcription_segments,
                                    api_key,
                                    min_tags=3,
                                    max_tags=8,
                                    model_name=get_gemini_model(),
                                )
                        except Exception as e:
                            error_msg = str(e)
                            if "404" in error_msg and "no longer available" in error_msg.lower():
                                error_msg = ("The selected Gemini model is no longer available.\n"
                                             "Please go to Settings → AI Tag Suggestions and choose a current model "
                                             "(e.g. gemini-2.5-flash).")
                            card.clear()
                            with card:
                                ui.label("AI Error").classes("text-h6 text-negative mb-2")
                                ui.label(error_msg).classes("text-sm text-grey-6 whitespace-pre-wrap")
                                ui.button("Close", on_click=ai_dialog.close).props("flat").classes("w-full mt-4")
                            return

                        if not suggestions:
                            card.clear()
                            with card:
                                ui.label("No tags suggested").classes("text-h6 mb-2")
                                ui.button("Close", on_click=ai_dialog.close).props("flat").classes("w-full mt-4")
                            return

                        # Phase 2: Replace content with tag selection UI (prominent checkboxes + edit + add custom)
                        card.clear()
                        with card:
                            ui.label("AI Suggested Tags").classes("text-h6 mb-2")
                            ui.label("Review, edit, and select the tags you want to add").classes("text-xs text-grey-6 mb-3")

                            # Each item: {"text": str, "selected": bool}
                            tag_items = [{"text": tag, "selected": True} for tag in suggestions]

                            def get_selected_count():
                                return sum(1 for item in tag_items if item.get("selected") and item.get("text"))

                            items_container = ui.column().classes("w-full gap-2 mb-2")

                            def refresh_items():
                                items_container.clear()
                                with items_container:
                                    for idx, item in enumerate(tag_items):
                                        text = item.get("text") or ""
                                        with ui.row().classes("items-center gap-2 w-full py-0.5"):
                                            # Prominent labeled checkbox (this is the main selectable control)
                                            cb = ui.checkbox(
                                                text or "(empty tag)",
                                                value=bool(item.get("selected"))
                                            ).props("dense")

                                            def make_cb_handler(i=idx):
                                                def handler(e):
                                                    tag_items[i]["selected"] = bool(getattr(e, "value", False))
                                                    update_add_button()
                                                return handler


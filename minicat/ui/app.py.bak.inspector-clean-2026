        batch_client = ui.input("Add to Client (by name)", placeholder="Leave empty to keep existing").props("dense")

        batch_tags = ui.input("Add Tags (comma separated)", placeholder="e.g. interview, b-roll").props("dense")

        async def apply_batch_edit():
            selected = state.get_selected_videos()
            if not selected:
                return

            updates = {}
            if batch_camera.value:
                updates["camera"] = batch_camera.value.strip()
            if batch_operator.value:
                updates["operator"] = batch_operator.value.strip()
            if batch_location.value:
                updates["location"] = batch_location.value.strip()
            if batch_lens.value:
                updates["lens"] = batch_lens.value.strip()

            # Handle batch client assignment (adds client to projects of selected clips)
            if batch_client.value:
                client_name = batch_client.value.strip()
                if client_name:
                    # Find or create client
                    existing_clients = db.get_clients(state.catalog_root)
                    target_client = next((c for c in existing_clients if c.name.lower() == client_name.lower()), None)
                    if not target_client:
                        target_client = db.create_or_update_client(state.catalog_root, Client(name=client_name))

                    projects_in_selection = {c.project for c in selected if c.project}
                    for p in projects_in_selection:
                        current_client_ids = [c.id for c in db.get_clients_for_project(state.catalog_root, p)]
                        if target_client.id not in current_client_ids:
                            current_client_ids.append(target_client.id)
                            db.set_project_clients(state.catalog_root, p, current_client_ids)
                    ui.notify(f"Added client '{client_name}' to projects in selection", color="positive")

            new_tags = []
            if batch_tags.value:
                new_tags = [t.strip() for t in batch_tags.value.split(",") if t.strip()]

            updated_count = 0
            total = len(selected)
            for i, clip in enumerate(selected, 1):
                if not clip.id:
                    continue

                clip_updates = updates.copy()

                # Handle tags (merge with existing)
                if new_tags:
                    current_tags = set(clip.tags or [])
                    current_tags.update(new_tags)
                    try:
                        await asyncio.to_thread(
                            db.set_video_tags, state.catalog_root, clip.id, list(current_tags)
                        )
                    except Exception:
                        pass

                if clip_updates:
                    try:
                        await asyncio.to_thread(
                            db.update_video_fields, state.catalog_root, clip.id, **clip_updates
                        )
                        updated_count += 1
                    except Exception:
                        pass
                elif new_tags:
                    updated_count += 1

                # Yield so the UI doesn't feel like it loses connection during bigger batches
                if i % 2 == 0 or i == total:
                    await asyncio.sleep(0)

            if updated_count:
                refresh_all_ui(state)
                ui.notify(f"Updated {updated_count} clips", color="positive")

                # Clear the form
                batch_camera.value = ""
                batch_operator.value = ""
                batch_location.value = ""
                batch_lens.value = ""
                batch_tags.value = ""

        ui.button("Apply to Selected Clips", icon="check", on_click=apply_batch_edit, color="primary").props("size=sm").classes("w-full")

    # Other batch actions
    with ui.row().classes("gap-2 w-full"):

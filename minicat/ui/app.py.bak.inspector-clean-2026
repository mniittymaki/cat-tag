async def _do_batch_proxy_generation(
    state: AppState,
    selected: list,
    preset: str,
    audio_mode_str: str,
):
    """Actual async proxy generation with progress dialog using the chosen preset."""
    progress_dialog = ui.dialog()
    with progress_dialog, ui.card().classes("w-[520px]"):
        ui.label("Generating Proxies").classes("text-h5 mb-2")

        progress_bar = ui.linear_progress(value=0, show_value=True).classes("w-full mt-2")
        status_label = ui.label("Starting...").classes("text-sm mt-2")
        file_label = ui.label("").classes("text-xs text-grey-6")

        close_btn = ui.button("Close", on_click=progress_dialog.close).props("flat").classes("mt-4 w-full")
        close_btn.visible = False

    progress_dialog.open()
    await asyncio.sleep(0.05)

    # Pre-flight ffmpeg check with nice dialog
    try:
        from minicat.core.video import find_ffmpeg, ffmpeg_supports_prores
        find_ffmpeg()
    except RuntimeError:
        progress_dialog.close()
        show_ffmpeg_required_dialog()
        return

    # Extra safety: if the dialog somehow passed a ProRes preset but ffmpeg doesn't support it
    effective_preset = preset
    if "ProRes" in preset and not ffmpeg_supports_prores():
        effective_preset = "H.264"
        print("[Proxy] Warning: ProRes requested but not supported by ffmpeg — falling back to H.264")

    success = 0
    failed = 0
    total = len(selected)

    # Determine audio mode
    audio_mode = "copy" if "Copy source" in audio_mode_str else "pcm"

    for i, clip in enumerate(selected, 1):
        progress_bar.value = i / total
        status_label.text = f"Processing {i} / {total}"
        file_label.text = clip.filename
        ui.update(progress_bar, status_label, file_label)
        await asyncio.sleep(0.01)

        try:
            proxy_dir = state.catalog_root / "proxies" / (clip.project or "Uncategorized")
            proxy_dir.mkdir(parents=True, exist_ok=True)
            proxy_name = Path(clip.path).stem + "_proxy.mov"
            proxy_out = proxy_dir / proxy_name

            if "ProRes" in effective_preset:
                height = 1080 if "1080p" in effective_preset else (720 if "720p" in effective_preset else 540)

                await asyncio.to_thread(
                    video.create_proxy,
                    source_path=clip.path,
                    output_path=proxy_out,
                    height=height,
                    codec="prores_proxy",
                    subtle_watermark=True,
                    watermark_text="CAT+TAG",
                    watermark_size=18,
                    watermark_opacity=0.4,
                    burn_original_timecode=True,
                    audio_mode=audio_mode,
                )
            else:
                height = 720 if "720p" in effective_preset else 540
                bitrate = 4000 if height == 720 else 2000
                gop = 24

                await asyncio.to_thread(
                    video.create_proxy,
                    source_path=clip.path,
                    output_path=proxy_out,
                    height=height,
                    codec="h264",
                    bitrate=bitrate,
                    gop_size=gop,
                    subtle_watermark=True,
                    watermark_text="CAT+TAG",
                    watermark_size=18,
                    watermark_opacity=0.4,
                    burn_original_timecode=True,
                    audio_mode=audio_mode,
                )

            success += 1
        except Exception as err:
            failed += 1
            print(f"[Proxy] Failed for {clip.filename}: {err}")

    progress_bar.value = 1.0
    status_label.text = "Finished"
    file_label.text = ""
    ui.update(progress_bar, status_label, file_label)

    close_btn.visible = True
    ui.update(close_btn)

    refresh_all_ui(state)

    msg = f"Generated proxies for {success} clips"
    if failed:
        msg += f", {failed} failed"
    ui.notify(msg, color="positive" if failed == 0 else "warning", duration=6)



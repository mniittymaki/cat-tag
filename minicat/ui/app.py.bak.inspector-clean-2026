def refresh_all_ui(state: AppState) -> None:
    """Central helper: call this after any mutation so the user sees changes everywhere immediately.
    All major refreshables are now parameterless so .refresh() is reliable.
    """
    state.reload()
    main_content.refresh()
    inspector_content.refresh()
    left_drawer_content.refresh()
    rich_tags_section.refresh()

    # Sync the topbar search input with current filter text (keeps it consistent)
    try:
        search_input = globals().get('_header_search_input')
        if search_input:
            current_text = state.filters.text or ""
            # Only update if different to avoid unnecessary events
            if getattr(search_input, 'value', None) != current_text:
                search_input.value = current_text
    except Exception:
        pass



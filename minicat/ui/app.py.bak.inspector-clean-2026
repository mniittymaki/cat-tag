    state = get_state()
    if not state or not video.id:
        return
    if _rebuild_clip_previews_and_metadata(state, video):
        # Update the selected video reference
        refreshed = db.get_video_by_path(state.catalog_root, video.path)
        if refreshed:
            state.selected = refreshed
